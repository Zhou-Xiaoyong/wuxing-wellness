---
import BaseLayout from './BaseLayout.astro';
import Disclaimer from '../components/Disclaimer.astro';
import ShareButtons from '../components/ShareButtons.astro';
import { SITE } from '../consts';
import { elementMap } from '../data/elements';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author?: string;
  element?: keyof typeof elementMap;
  heroImage?: string;
}
const { title, description, pubDate, updatedDate, author = SITE.author, element, heroImage } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
const el = element ? elementMap[element] : null;
const heroPath = heroImage || (element ? `/hero-${element}.png` : '/og-default.png');
const heroUrl = new URL(heroPath, Astro.site).href;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: heroUrl,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Person', name: author },
  publisher: { '@type': 'Organization', name: SITE.title, logo: { '@type': 'ImageObject', url: new URL('/favicon.svg', Astro.site).href } },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical.href },
  inLanguage: 'en',
};
---

<BaseLayout title={title} description={description} type="article" image={heroPath}>
  <article class="section" data-element={element ?? ''}>
    <div class="container prose">
      <p class="eyebrow" style="font-family:var(--sans);font-size:12px;letter-spacing:3px;text-transform:uppercase;color:var(--crimson)">
        {el ? `${el.name} Element` : 'Journal'}
      </p>
      <h1>{title}</h1>
      <p style="color:var(--ink-faint);font-family:var(--sans);font-size:14px">
        By {author} · {pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <img src={heroPath} alt={title} loading="lazy" style="width:100%;border-radius:var(--radius);margin:8px 0 28px" />
      <slot />
      <ShareButtons title={title} />
      <Disclaimer />
      <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline />
    </div>
  </article>
</BaseLayout>

<script>
  // Progressive enhancement: turn ☐ self-check tables into interactive checkboxes with a live count.
  // Read the element key from the article so we can pre-fill the full quiz later.
  const scElement = (document.querySelector('article') as HTMLElement | null)?.dataset.element ?? '';

  document.querySelectorAll('.prose table').forEach((table) => {
    const boxCells = Array.from(table.querySelectorAll('td')).filter((td) => td.textContent.trim() === '☐');
    if (!boxCells.length) return;
    boxCells.forEach((td) => {
      td.innerHTML = '<input type="checkbox" class="sc-check">';
    });
    const checks = table.querySelectorAll('input.sc-check');
    if (!checks.length) return;
    const bar = document.createElement('div');
    bar.className = 'sc-bar';
    bar.innerHTML =
      '<span><b class="sc-count">0</b> / ' + checks.length + ' feel like me</span>' +
      '<div class="sc-track"><div class="sc-fill"></div></div>' +
      '<button class="sc-btn" type="button">Reset</button>' +
      '<a class="sc-cta" href="/quizzes/five-elements-personality-test">Full quiz →</a>';
    table.parentNode!.insertBefore(bar, table.nextSibling);
    const count = bar.querySelector('.sc-count') as HTMLElement;
    const fill = bar.querySelector('.sc-fill') as HTMLElement;
    const reset = bar.querySelector('.sc-btn') as HTMLButtonElement;
    const cta = bar.querySelector('.sc-cta') as HTMLAnchorElement;
    const key = 'sc:' + location.pathname;
    let saved: number[] = [];
    try { saved = JSON.parse(localStorage.getItem(key) || '[]'); } catch (e) { saved = []; }
    checks.forEach((c, i) => {
      if (saved.includes(i)) c.checked = true;
      c.addEventListener('change', update);
    });
    function update() {
      const n = Array.from(checks).filter((c) => (c as HTMLInputElement).checked).length;
      count.textContent = String(n);
      fill.style.width = (n / checks.length) * 100 + '%';
      try {
        localStorage.setItem(key, JSON.stringify(Array.from(checks).map((c, i) => (c as HTMLInputElement).checked ? i : -1).filter((i) => i >= 0)));
      } catch (e) { /* ignore */ }
    }
    reset.addEventListener('click', () => {
      checks.forEach((c) => ((c as HTMLInputElement).checked = false));
      update();
    });
    // Carry the self-check into the full quiz so prior selections aren't lost.
    cta.addEventListener('click', () => {
      const total = checks.length;
      const flagged = Array.from(checks).filter((c) => (c as HTMLInputElement).checked).length;
      const score = Math.round((flagged / total) * 100);
      const params = new URLSearchParams();
      if (scElement) {
        params.set('from', scElement);
        params.set('total', String(total));
        params.set('flagged', String(flagged));
        params.set('score', String(score));
      }
      const qs = params.toString();
      cta.href = '/quizzes/five-elements-personality-test' + (qs ? '?' + qs : '');
    });
    update();
  });
</script>
