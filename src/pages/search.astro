---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search | Five Elements Balance" description="Search five-element articles, recipes and guides.">
  <section class="section">
    <div class="container prose">
      <h1>Search</h1>
      <p style="color:var(--ink-soft)">Find articles, recipes and element guides across the site.</p>
      <div id="search"></div>
    </div>
  </section>
</BaseLayout>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline src="/pagefind/pagefind-ui.js"></script>
<script is:inline>
  // Pagefind UI ships as an IIFE that assigns `window.PagefindUI` (not an ES module),
  // so it must be loaded via <script src> and instantiated from the global.
  window.addEventListener('DOMContentLoaded', function () {
    var el = document.getElementById('search');
    if (typeof window.PagefindUI === 'undefined') {
      if (el) el.innerHTML = '<p style="color:var(--ink-faint)">Search index is still building. Refresh the page in a moment.</p>';
      return;
    }
    new window.PagefindUI({
      element: '#search',
      showSubResults: true,
      bundlePath: '/pagefind/',
      translations: { placeholder: 'Search articles and recipes...' },
    });
  });
</script>

<style is:global>
  .pf-ui { --pf-ui-background: transparent; --pf-ui-border-color: rgba(33,31,27,.18); }
  .pf-ui input { font-family: var(--sans); }
</style>
