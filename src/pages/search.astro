---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search | Five Elements Balance" description="Search five-element articles, recipes and guides.">
  <section class="section">
    <div class="container prose">
      <h1>Search</h1>
      <p style="color:var(--ink-soft)">Find articles, recipes and element guides across the site.</p>
      <div id="search"></div>
    </div>
  </section>
</BaseLayout>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
<script is:inline>
  (function () {
    var el = document.getElementById('search');
    import('/pagefind/pagefind-ui.js')
      .then(function (mod) {
        var UI = mod.PagefindUI || mod.default;
        if (!UI) throw new Error('PagefindUI constructor not found in module');
        new UI({
          element: '#search',
          showSubResults: true,
          bundlePath: '/pagefind/',
          translations: { placeholder: 'Search articles and recipes...' },
        });
      })
      .catch(function (err) {
        console.error('Pagefind init failed:', err);
        el.innerHTML = '<p style="color:var(--ink-faint)">Search index is still building. Refresh the page in a moment.</p>';
      });
  })();
</script>

<style is:global>
  .pf-ui { --pf-ui-background: transparent; --pf-ui-border-color: rgba(33,31,27,.18); }
  .pf-ui input { font-family: var(--sans); }
</style>
